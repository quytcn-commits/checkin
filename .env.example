# Sao chép file này thành ".env" rồi chỉnh giá trị

# Cổng chạy server
PORT=3000

# Mật khẩu trang quản trị (/admin) và trang quay số (/draw). ĐỔI trước khi dùng thật!
ADMIN_PASSWORD=admin123

# Tên sự kiện hiển thị trên web
EVENT_NAME=Year End Party 2026

# Muối (salt) để hash CCCD - đặt 1 chuỗi ngẫu nhiên bất kỳ, KHÔNG đổi giữa chừng
CCCD_SALT=doi-chuoi-nay-thanh-ngau-nhien

# ----- Geofence (giới hạn vị trí check-in) -----
# Bật = chỉ check-in trong bán kính mới được tính hợp lệ (vào lucky draw)
GEOFENCE_ENABLED=false
# Toạ độ trung tâm địa điểm (lấy trên Google Maps: chuột phải -> toạ độ)
GEOFENCE_LAT=10.762622
GEOFENCE_LNG=106.660172
# Bán kính cho phép (mét)
GEOFENCE_RADIUS=300
